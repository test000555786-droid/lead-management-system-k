# Database
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
AUTH_SECRET="your-random-secret-key-min-32-chars-long"

# Seed (optional — used by seed script)
SEED_ADMIN_EMAIL="admin@company.com"
SEED_ADMIN_PASSWORD="changeme123"
SEED_ADMIN_NAME="Admin User"

# LLM Parser for import (Paste/Word/Excel)
# You can provide multiple Groq API keys separated by commas to bypass rate limits
GROQ_API_KEY="gsk_key1,gsk_key2"
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
