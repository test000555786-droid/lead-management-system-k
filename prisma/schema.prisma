generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role            Role           @default(STAFF)
  active          Boolean        @default(true)
  canViewAllLeads Boolean        @default(false)
  createdAt       DateTime       @default(now())
  activityLogs  ActivityLog[]
  followUps     FollowUp[]
  importBatches ImportBatch[]
  leadsAssigned Lead[]         @relation("AssignedLeads")
  leadsCreated  Lead[]         @relation("CreatedLeads")
  staffSessions StaffSession[]
}

model StaffSession {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @default(now())
  firstPingAt DateTime @default(now())
  lastPingAt  DateTime @default(now())
  duration    Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Lead {
  id              String        @id @default(cuid())
  businessName    String
  contactPerson   String?
  phone           String
  phoneNormalized String
  altPhone        String?
  email           String?
  website         String?
  address         String?
  city            String
  state           String
  country         String        @default("India")
  category        String
  source          String?
  status          LeadStatus    @default(NEW)
  tags            String[]      @default([])
  notes           String?
  assignedToId    String?
  createdById     String
  importBatchId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activityLogs    ActivityLog[]
  denyReason      DenyReason?
  followUps       FollowUp[]
  assignedTo      User?         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdBy       User          @relation("CreatedLeads", fields: [createdById], references: [id])
  importBatch     ImportBatch?  @relation(fields: [importBatchId], references: [id])

  @@index([city, state, country])
  @@index([category])
  @@index([status])
  @@index([phoneNormalized])
  @@index([assignedToId])
}

model FollowUp {
  id             String    @id @default(cuid())
  leadId         String
  staffId        String
  notes          String
  outcome        String?
  nextFollowUpAt DateTime?
  createdAt      DateTime  @default(now())
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  staff          User      @relation(fields: [staffId], references: [id])

  @@index([leadId])
  @@index([nextFollowUpAt])
}

model DenyReason {
  id        String   @id @default(cuid())
  leadId    String   @unique
  category  String
  details   String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model ImportBatch {
  id           String   @id @default(cuid())
  source       String
  fileName     String?
  importedById String
  rowCount     Int
  createdAt    DateTime @default(now())
  importedBy   User     @relation(fields: [importedById], references: [id])
  leads        Lead[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  leadId    String
  userId    String
  action    String
  detail    String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([leadId])
}

enum Role {
  ADMIN
  STAFF
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  INTERESTED
  CONVERTED
  NOT_INTERESTED
}
